# ==========================================
# 基础设施层：大模型路由与网关 (Clients Layer)
# ==========================================
# 默认使用 DeepSeek 作为主逻辑引擎 (完全兼容 OpenAI SDK)
DEEPSEEK_API_KEY="sk-..."
DEEPSEEK_BASE_URL="https://api.deepseek.com" 

# 模型精细化路由 (Model Routing)
# 推荐使用 deepseek-reasoner (R1) 进行世界观推演、结构化大纲生成与状态机硬校验
LLM_MODEL_REASONING="deepseek-reasoner"
# 推荐使用 deepseek-chat (V3) 进行高并发的百万字正文循环铺陈
LLM_MODEL_GENERATION="deepseek-chat"

# 备用降级通道 (Fallback Node)
# 当主节点因限流或网络抖动熔断时，自动切换至备用引擎 (如本地 vLLM 或其他云端 API)
FALLBACK_API_KEY="sk-..."
FALLBACK_BASE_URL="http://localhost:8000/v1"
FALLBACK_MODEL="Qwen2.5-72B-Instruct"

# ==========================================
# 引擎中枢：运行参数与工业级容错 (Engine Config)
# ==========================================
# 自动化调用器参数：重试、退避与超时 (基于 Tenacity)
MAX_RETRIES=5                            # 单次 API 调用的最大重试次数
RETRY_BACKOFF_FACTOR=2                   # 指数退避的乘数因子
RETRY_MAX_DELAY=60                       # 单次重试最大等待时间(秒)
API_TIMEOUT_SECONDS=120                  # 防止长连接假死，强制释放资源

# 调度器参数：生成温度与长度硬限制
TEMPERATURE_REASONING=0.3                # 逻辑锁与状态机校验，极低温度确保输出结构化 JSON 不变形
TEMPERATURE_GENERATION=0.85              # 正文生成，适度提高以保证文学修辞的丰富性
MAX_TOKENS_CHAPTER=4000                  # 单次章节生成的 Token 拦截上限

# ==========================================
# 记忆层：防遗忘与状态管理 (Memory Layer)
# ==========================================
VECTOR_DB_TYPE="chroma"                  # 可选项: chroma, qdrant
VECTOR_DB_PERSIST_DIR="./data/chroma_db" # 向量数据库本地持久化路径
MAX_CONTEXT_WINDOW=32000                 # 滑动窗口的上下文 Token 截断阈值，防止 OOM

# ==========================================
# 辅助工具：异步监控与日志 (Utils Layer)
# ==========================================
LOG_LEVEL="INFO"                         # 可选项: DEBUG, INFO, WARNING, ERROR
LOG_ROTATION="500 MB"                    # 日志文件按大小切分，防止长时间运行撑爆云盘
LOG_RETENTION="10 days"                  # 日志保留周期